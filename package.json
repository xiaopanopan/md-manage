{
  "name": "digital-zen",
  "version": "0.1.0",
  "description": "A minimalist Markdown desktop editor",
  "main": "dist/main/main.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "preview": "vite preview",
    "test": "vitest",
    "package": "vite build && electron-builder"
  },
  "keywords": ["markdown", "editor", "electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "immer": "^10.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.0.0"
  }
}
